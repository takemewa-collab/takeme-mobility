{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/dispatch/worker",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/monitor",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/monitor/autofix",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/monitor/e2e",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/invariants/check",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/invariants/metrics/snapshot",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/driver-maintenance",
      "schedule": "0 16 * * *"
    }
  ]
}
